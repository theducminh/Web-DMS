# ==========================================================================
# VDT Zero-Trust DMS — Mẫu biến môi trường. Copy thành .env trước khi chạy.
#   cp .env.example .env   (hoặc: make env)
# ==========================================================================
# LƯU Ý quan trọng:
#   - Docker --env-file KHÔNG cắt comment inline => KHÔNG đặt '# ...' sau giá trị số.
#   - Mỗi giá trị trên 1 dòng riêng. Comment đặt ở dòng riêng phía trên.

# --- App ---
NODE_ENV=development
API_PORT=3000

# Domain frontend dùng để cấu hình CORS / redirect SSO.
# DEV (manual run, vite dev port 5173):    APP_BASE_URL=http://localhost
# PROD (compose qua Nginx HTTPS 443):      APP_BASE_URL=https://localhost
APP_BASE_URL=http://localhost

# --- PostgreSQL via Supabase MANAGED (cloud) ---
# Project setup:
#   1. Tạo project free tier tại https://supabase.com/
#   2. Lấy connection string từ Settings → Database → Connection string
#   3. Apply schema 1 lần:  ./bootstrap-supabase.sh  (xem PROGRESS.md §3)
#
# DATABASE_URL = Supavisor Transaction Pooler (port 6543) → app runtime, hỗ trợ pgbouncer.
# DIRECT_URL   = Supavisor Session Pooler (port 5432) hoặc Direct DB → cho Prisma migrate.
DATABASE_URL=postgresql://postgres.<projectref>:<password>@aws-1-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=10
DIRECT_URL=postgresql://postgres.<projectref>:<password>@aws-1-<region>.pooler.supabase.com:5432/postgres

# --- Redis (Session, Blacklist, Rate-limit, BullMQ, ABAC cache) ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=vdt_redis
REDIS_URL=redis://:vdt_redis@redis:6379

# --- MinIO (Object Storage, S3 API, SSE-S3 AES-256) ---
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false

# Endpoint trình duyệt có thể truy cập (cho presigned URL Original-view diff/download).
# Để trống = browser sẽ KHÔNG resolve được "minio:9000" → ảnh/PDF preview vỡ.
# DEV (manual run, MinIO expose port 9000 ra host):
#     MINIO_PUBLIC_ENDPOINT=http://localhost:9000
# PROD (compose qua Nginx, regex ^/<bucket>/ proxy thẳng MinIO không strip path):
#     MINIO_PUBLIC_ENDPOINT=https://localhost
# (chọn 1 dòng phía dưới, comment dòng còn lại)
MINIO_PUBLIC_ENDPOINT=http://localhost:9000
# MINIO_PUBLIC_ENDPOINT=https://localhost

MINIO_ROOT_USER=vdt_minio
MINIO_ROOT_PASSWORD=vdt_minio_secret
MINIO_BUCKET=vdt-docs
# KMS single-key để MinIO bật SSE-S3 (AES-256) mà không cần KES (NFR-1.2)
MINIO_KMS_SECRET_KEY=vdt-demo-key:OMfWMJtx5cU4FJcy0o24wsIOVZ+tEHzxnNrryxoEe9Y=
# @aws-sdk/client-s3 đọc các biến này (alias của MINIO_ROOT_*)
S3_ACCESS_KEY=vdt_minio
S3_SECRET_KEY=vdt_minio_secret
S3_REGION=us-east-1

# --- JWT / Auth ---
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars_long
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars_long
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
BCRYPT_SALT_ROUNDS=10

# --- Google OAuth2 (SSO) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# DEV:  GOOGLE_CALLBACK_URL=http://localhost/api/v1/auth/google/callback
# PROD: GOOGLE_CALLBACK_URL=https://localhost/api/v1/auth/google/callback
GOOGLE_CALLBACK_URL=http://localhost/api/v1/auth/google/callback
# Domain restriction OPT-IN: để TRỐNG = chấp nhận mọi email Google (kể cả @gmail.com).
# Set giá trị (vd `viettel.com.vn`) nếu deploy cho doanh nghiệp muốn ép nhân sự nội bộ.
ALLOWED_EMAIL_DOMAIN=

# --- Email (Nodemailer — gửi OTP, kết quả review) ---
# Để trống SMTP_HOST ở môi trường dev -> hệ thống in OTP ra log thay vì gửi mail thật.
#
# Để bật Gmail SMTP thật (Production):
#   1. Vào myaccount.google.com → Security → 2-Step Verification (bật nếu chưa có)
#   2. Vào App passwords → tạo mới tên "VDT DMS"
#   3. Copy 16 ký tự (vd "abcd efgh ijkl mnop") — REMOVE SPACES khi paste vào SMTP_PASS
#   4. SMTP_USER = email Gmail của bạn
#   5. SMTP_FROM = "Display Name <email@gmail.com>"
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="VDT DMS <no-reply@vdt-dms.local>"

# --- Bảo mật / Nghiệp vụ (FR-3.2.1, FR-5.3.1) ---
OTP_TTL_SECONDS=300
ABAC_CACHE_TTL_SECONDS=300
DOC_LOCK_TTL_SECONDS=7200
MAX_UPLOAD_BYTES=52428800
TEXT_EXTRACT_MAX_BYTES=15728640
ANOMALY_DOWNLOAD_THRESHOLD=10
EMERGENCY_PIN=999999
LOCKDOWN_SAFE_IP=127.0.0.1

# --- Diff Engine Microservice (Luồng 18) ---
DIFF_ENGINE_URL=http://diff-engine:8000
