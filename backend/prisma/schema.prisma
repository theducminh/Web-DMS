// VDT Zero-Trust DMS — Lược đồ Database (PostgreSQL / Supabase)
// Bám sát phần "Database" của tài liệu thiết kế (11 bảng cốt lõi + bảng phụ trợ).
//
// SUPABASE NOTES:
// - Trên Supabase, source-of-truth là các file SQL trong `supabase/migrations/`
//   (vì những tính năng như partition audit_logs, INSERT-only, RLS, tích hợp
//   auth.users không biểu diễn được bằng Prisma migrate). Prisma ở đây đóng vai trò
//   Typed Client cho NestJS: chạy `prisma generate` (hoặc `prisma db pull` để introspect).
// - `profiles.id` là UUID khớp với `auth.users(id)` của Supabase (nếu dùng Supabase Auth).
//   Mặc định DB tự sinh bằng gen_random_uuid() (built-in PG13+, không cần extension).

generator client {
  provider      = "prisma-client-js"
  // native: máy host (dev). linux-musl-openssl-3.0.x: container Alpine (OpenSSL 3).
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  // URL chính cho app runtime — qua Supavisor transaction pooler (port 6543, pgbouncer mode).
  url       = env("DATABASE_URL")
  // URL trực tiếp (session pooler hoặc direct) cho `prisma migrate` / `prisma db push`.
  // Khi không set, fallback về DATABASE_URL.
  directUrl = env("DIRECT_URL")
}

// ---------------------------------------------------------------------------
// ENUMS
// ---------------------------------------------------------------------------
enum UserStatus {
  PENDING
  ACTIVE
  DISABLED

  @@map("user_status")
}

enum AuthProvider {
  LOCAL
  GOOGLE

  @@map("auth_provider")
}

enum ClearanceLevel {
  PUBLIC
  INTERNAL
  CONFIDENTIAL

  @@map("clearance_level")
}

enum ProjectStatus {
  ACTIVE
  ARCHIVED

  @@map("project_status")
}

enum ProjectRole {
  PM
  CONTRIBUTOR
  REVIEWER
  VIEWER

  @@map("project_role")
}

enum SecurityLevel {
  PUBLIC
  INTERNAL
  CONFIDENTIAL

  @@map("security_level")
}

enum DocumentStatus {
  DRAFT
  UNDER_REVIEW
  RELEASED
  LOCKED

  @@map("document_status")
}

enum ReleaseStatus {
  PROCESSING
  VERIFIED
  VIOLATED

  @@map("release_status")
}

// ---------------------------------------------------------------------------
// 1. departments — Phòng ban
// ---------------------------------------------------------------------------
model Department {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String    @unique @db.VarChar(100)
  description String?   @db.Text
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  profiles    Profile[]

  @@map("departments")
}

// ---------------------------------------------------------------------------
// 2. profiles — Hồ sơ nhân viên (FK trỏ auth.users(id) của Supabase)
// ---------------------------------------------------------------------------
model Profile {
  id             String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email          String         @unique @db.VarChar(255)
  passwordHash   String?        @map("password_hash") @db.VarChar(255) // null nếu đăng nhập Google SSO
  fullName       String         @map("full_name") @db.VarChar(100)
  displayName    String?        @map("display_name") @db.VarChar(100)
  dob            DateTime?      @db.Date
  gender         String?        @db.VarChar(10)
  phone          String?        @db.VarChar(20)
  authProvider   AuthProvider   @default(LOCAL) @map("auth_provider")
  departmentId   String?        @map("department_id") @db.Uuid
  title          String?        @db.VarChar(50)
  clearanceLevel ClearanceLevel @default(INTERNAL) @map("clearance_level")
  status         UserStatus     @default(PENDING)
  createdAt      DateTime       @default(now()) @map("created_at") @db.Timestamptz()

  department         Department?              @relation(fields: [departmentId], references: [id])
  ownedProjects      Project[]                @relation("ProjectOwner")
  projectMemberships ProjectMember[]
  uploadedVersions   DocumentVersion[]
  createdDocuments   Document[]               @relation("DocumentCreator")
  lockedDocuments    Document[]               @relation("DocumentLocker")
  auditLogs          AuditLog[]
  projectPreferences UserProjectPreference[]

  @@index([departmentId])
  @@map("profiles")
}

// ---------------------------------------------------------------------------
// 3. casbin_rule — Luật phân quyền (do casbin-prisma-adapter quản lý)
//    Tài liệu gọi là cabin_rule; tên bảng chuẩn cho adapter là casbin_rule.
// ---------------------------------------------------------------------------
model CasbinRule {
  id    Int     @id @default(autoincrement())
  ptype String  @db.VarChar(100)
  v0    String? @db.VarChar(100) // Subject (User/Role)
  v1    String? @db.VarChar(100) // Object (Tài liệu/Dự án)
  v2    String? @db.VarChar(100) // Action (Đọc/Sửa/Tải)
  v3    String? @db.VarChar(100) // Context 1 (Thời gian/Trạng thái)
  v4    String? @db.VarChar(100) // Context 2 (Mức độ mật)
  v5    String? @db.VarChar(100)

  @@map("casbin_rule")
}

// ---------------------------------------------------------------------------
// 4. projects — Dự án
// ---------------------------------------------------------------------------
model Project {
  id          String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String        @db.VarChar(255)
  description String?       @db.Text
  status      ProjectStatus @default(ACTIVE)
  ownerId     String        @map("owner_id") @db.Uuid
  createdAt   DateTime      @default(now()) @map("created_at") @db.Timestamptz()

  owner       Profile                 @relation("ProjectOwner", fields: [ownerId], references: [id])
  members     ProjectMember[]
  folders     Folder[]
  documents   Document[]
  releases    Release[]
  preferences UserProjectPreference[]

  @@index([ownerId])
  @@map("projects")
}

// ---------------------------------------------------------------------------
// 5. project_members — Thành viên & vai trò trong dự án
// ---------------------------------------------------------------------------
model ProjectMember {
  id          String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId   String      @map("project_id") @db.Uuid
  userId      String      @map("user_id") @db.Uuid
  projectRole ProjectRole @map("project_role")
  assignedAt  DateTime    @default(now()) @map("assigned_at") @db.Timestamptz()

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    Profile @relation(fields: [userId], references: [id])

  @@unique([projectId, userId])
  @@index([userId])
  @@map("project_members")
}

// ---------------------------------------------------------------------------
// 6. folders — Cây thư mục dự án
// ---------------------------------------------------------------------------
model Folder {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId String   @map("project_id") @db.Uuid
  parentId  String?  @map("parent_id") @db.Uuid
  name      String   @db.VarChar(255)
  isLocked  Boolean  @default(false) @map("is_locked") // thư mục cốt lõi từ template
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parent    Folder?    @relation("FolderTree", fields: [parentId], references: [id])
  children  Folder[]   @relation("FolderTree")
  documents Document[]

  @@index([projectId])
  @@index([parentId])
  @@map("folders")
}

// ---------------------------------------------------------------------------
// 7. documents — Quản lý file & workflow (Pessimistic Locking qua locked_by)
// ---------------------------------------------------------------------------
model Document {
  id                  String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId           String         @map("project_id") @db.Uuid
  folderId            String?        @map("folder_id") @db.Uuid
  title               String         @db.VarChar(255)
  securityLevel       SecurityLevel  @default(INTERNAL) @map("security_level")
  status              DocumentStatus @default(DRAFT)
  lockedBy            String?        @map("locked_by") @db.Uuid
  createdBy           String         @map("created_by") @db.Uuid
  isDeleted           Boolean        @default(false) @map("is_deleted")
  publishedVersionId  String?        @map("published_version_id") @db.Uuid
  createdAt           DateTime       @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt           DateTime       @updatedAt @map("updated_at") @db.Timestamptz()

  project   Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  folder    Folder?           @relation(fields: [folderId], references: [id])
  creator   Profile           @relation("DocumentCreator", fields: [createdBy], references: [id])
  locker    Profile?          @relation("DocumentLocker", fields: [lockedBy], references: [id])
  versions  DocumentVersion[]

  @@index([projectId])
  @@index([folderId])
  @@index([isDeleted])
  @@map("documents")
}

// ---------------------------------------------------------------------------
// 8. document_versions — Lịch sử file vật lý (Append-only, bất biến)
// ---------------------------------------------------------------------------
model DocumentVersion {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  documentId        String   @map("document_id") @db.Uuid
  versionNo         Int      @map("version_no")
  storageKey        String   @map("storage_key") @db.VarChar(500)
  rawTextStorageKey String?  @map("raw_text_storage_key") @db.VarChar(500)
  fileType          String   @map("file_type") @db.VarChar(20)
  fileSize          BigInt   @map("file_size")
  textExtracted     Boolean  @default(false) @map("text_extracted")
  commitMessage     String?  @map("commit_message") @db.Text
  uploadedBy        String   @map("uploaded_by") @db.Uuid
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz()

  document Document                  @relation(fields: [documentId], references: [id], onDelete: Cascade)
  uploader Profile                   @relation(fields: [uploadedBy], references: [id])
  releases ReleaseDocumentVersion[]

  @@unique([documentId, versionNo])
  @@index([documentId])
  @@map("document_versions")
}

// ---------------------------------------------------------------------------
// 9. audit_logs — Nhật ký chống chối bỏ (Hash Chaining, INSERT-only)
//    Vận hành: cấu hình Table Partitioning theo tháng ở tầng DB/migration.
// ---------------------------------------------------------------------------
model AuditLog {
  // PK kép (id, timestamp): timestamp là partition key bắt buộc nằm trong khóa chính
  // do bảng được PARTITION BY RANGE (timestamp) — xem supabase/migrations/0001.
  id           BigInt   @default(autoincrement())
  timestamp    DateTime @default(now()) @db.Timestamptz()
  userId       String?  @map("user_id") @db.Uuid
  action       String   @db.VarChar(50)
  targetId     String?  @map("target_id") @db.VarChar(255)
  ipAddress    String?  @map("ip_address") @db.VarChar(45)
  isSuccess    Boolean  @default(true) @map("is_success")
  failReason   String?  @map("fail_reason") @db.Text
  metadata     Json?    // payload before/after cho thao tác admin
  // Hash Chaining do trigger DB tự tính (compute_audit_hash) — app INSERT không cần truyền.
  previousHash String   @default("") @map("previous_hash") @db.VarChar(64)
  currentHash  String   @default("") @map("current_hash") @db.VarChar(64)

  user Profile? @relation(fields: [userId], references: [id])

  @@id([id, timestamp])
  @@index([userId])
  @@index([action])
  @@index([timestamp])
  @@map("audit_logs")
}

// ---------------------------------------------------------------------------
// 10. project_templates — Mẫu dự án
// ---------------------------------------------------------------------------
model ProjectTemplate {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String   @unique @db.VarChar(100)
  templateType String   @unique @map("template_type") @db.VarChar(50)
  description  String?  @db.Text
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()

  folders TemplateFolder[]

  @@map("project_templates")
}

// ---------------------------------------------------------------------------
// 11. template_folders — Cấu trúc thư mục của mẫu (Path Materialization)
// ---------------------------------------------------------------------------
model TemplateFolder {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  templateId   String   @map("template_id") @db.Uuid
  name         String   @db.VarChar(255)
  parentPath   String?  @map("parent_path") @db.VarChar(500)
  isLocked     Boolean  @default(false) @map("is_locked")
  displayOrder Int      @default(0) @map("display_order")
  description  String?  @db.VarChar(255)

  template ProjectTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId])
  @@map("template_folders")
}

// ---------------------------------------------------------------------------
// Bảng phụ trợ
// ---------------------------------------------------------------------------

// Release — gói phát hành (chốt hồ sơ)
model Release {
  id           String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId    String        @map("project_id") @db.Uuid
  releaseName  String        @map("release_name") @db.VarChar(255)
  templateType String?       @map("template_type") @db.VarChar(50)
  description  String?       @db.Text
  status       ReleaseStatus @default(PROCESSING)
  complianceScore Int?       @map("compliance_score")
  frozenAt     DateTime?     @map("frozen_at") @db.Timestamptz()
  createdBy    String        @map("created_by") @db.Uuid
  createdAt    DateTime      @default(now()) @map("created_at") @db.Timestamptz()

  project          Project                  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  documentVersions ReleaseDocumentVersion[]

  @@index([projectId])
  @@map("releases")
}

// release_document_versions — Snapshot bất biến: gói release trỏ tới version cụ thể
model ReleaseDocumentVersion {
  id                String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  releaseId         String @map("release_id") @db.Uuid
  documentVersionId String @map("document_version_id") @db.Uuid

  release         Release         @relation(fields: [releaseId], references: [id], onDelete: Cascade)
  documentVersion DocumentVersion @relation(fields: [documentVersionId], references: [id])

  @@unique([releaseId, documentVersionId])
  @@map("release_document_versions")
}

// user_project_preferences — Ghim dự án (Pinned Projects), không ảnh hưởng người khác
model UserProjectPreference {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String  @map("user_id") @db.Uuid
  projectId String  @map("project_id") @db.Uuid
  isStarred Boolean @default(false) @map("is_starred")

  user    Profile @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
  @@map("user_project_preferences")
}
